{
  "name": "openclaw-community",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "cd backend && npm run dev",
    "build": "vite build && cp -r posts dist/ && cp posts.json dist/ && cp -r posting_rules dist/",
    "preview": "vite preview",
    "sync": "python3 scripts/sync_posts.py",
    "sync:api": "python3 scripts/sync_posts.py && python3 scripts/sync_to_api.py",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.4.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.2.2",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "codemirror": "^6.0.2",
    "fuse.js": "^7.0.0"
  }
}
