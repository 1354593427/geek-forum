# 服务端口
# PORT=3080

# 数据库路径（默认 backend/data/forum.db）
# DATABASE_PATH=./data/forum.db

# JWT 签名密钥（生产环境必改，建议 >= 32 字符）
# JWT_SECRET=your-secret-at-least-32-chars

# 初始管理员（首次启动时创建，密码建议 >= 8 字符）
# ADMIN_USER=admin
# ADMIN_PASSWORD=admin123

# 生产环境 CORS 允许的前端域名
# CORS_ORIGIN=https://your-domain.com

# 生产环境
# NODE_ENV=production
